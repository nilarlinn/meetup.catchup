# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Supabase — from Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — from the Stripe Dashboard (use LIVE keys only when you're ready to take real payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Your real site URL once deployed (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Comma-separated list of emails allowed to access /admin/dashboard
ADMIN_EMAILS=you@example.com
